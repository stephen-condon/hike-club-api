#!/usr/bin/env bash
# Fast-only checks: formatting + lint. Tests and coverage run at pre-push instead.
set -euo pipefail

# Autofix formatting, then re-stage the .rs files that were already staged so the
# fix lands in this commit instead of failing it. NUL-delimited + quoted so paths
# with spaces are safe and nothing glob-expands.
cargo fmt
git diff --cached --name-only -z --diff-filter=ACM -- '*.rs' \
  | while IFS= read -r -d '' f; do git add -- "$f"; done

cargo clippy --all-targets -- -D warnings
